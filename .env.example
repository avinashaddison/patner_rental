# ============================================================================
# Companion Ranchi — environment configuration
# Copy to .env and fill in. Dev works with placeholders + OTP_CONSOLE=true.
# ============================================================================

# ---- Core ----
NODE_ENV=development
PORT=4000
APP_NAME=Companion Ranchi
API_BASE_URL=http://localhost:4000
ADMIN_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://companion:companion@localhost:5432/companion_ranchi?schema=public

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=change_me_access_secret_dev
JWT_REFRESH_SECRET=change_me_refresh_secret_dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ADMIN_JWT_SECRET=change_me_admin_secret_dev

# ---- OTP / SMS ----
# In dev keep OTP_CONSOLE=true to print OTPs to the server log (no SMS needed).
OTP_CONSOLE=true
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
# MSG91 (India) — set when going live
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CMPRNC
MSG91_TEMPLATE_ID=

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
# RazorpayX for automated payouts (optional)
RAZORPAYX_ACCOUNT_NUMBER=

# ---- Cloudflare R2 (S3 compatible) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=companion-ranchi
R2_PUBLIC_BASE_URL=https://media.companionranchi.com
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# ---- Firebase Cloud Messaging (push only — NOT used for login) ----
# Path to the service account JSON (download from Firebase console)
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
FIREBASE_PROJECT_ID=

# ---- Google OAuth (Google login — Authorization Code flow, no Firebase) ----
# From Google Cloud Console → APIs & Services → Credentials → Web application
# OAuth client. The secret stays server-side; the app never sees it.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must EXACTLY match an "Authorized redirect URI" on that OAuth client.
# Dev (with `adb reverse tcp:4000 tcp:4000`): http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Custom scheme the backend bounces back to (the mobile app intercepts it).
APP_OAUTH_SCHEME=companionranchi

# ---- Business rules ----
DEFAULT_COMMISSION_RATE=20          # platform commission percent
REFERRAL_REWARD_AMOUNT=100          # wallet credit (INR) after referee's first booking
MIN_PAYOUT_AMOUNT=500
DEFAULT_CITY=Ranchi
MIN_AGE=18

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Admin seed (created by `npm run seed`) ----
SEED_ADMIN_EMAIL=admin@companionranchi.com
SEED_ADMIN_PASSWORD=Admin@12345
