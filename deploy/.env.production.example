# ============================================================================
# Companion Ranchi — PRODUCTION environment template
# ----------------------------------------------------------------------------
# Copy these into your secret manager / platform env (Render, Railway, pm2 .env,
# Docker secrets). NEVER commit a filled-in file. Variable NAMES match
# /.env.example exactly so the backend zod config validates them unchanged.
#
# Replace every value marked <...>. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================================

# ---- Core ----
NODE_ENV=production
PORT=4000
APP_NAME=Companion Ranchi
# Public HTTPS origin of the backend (used in payment callbacks, links, FCM).
API_BASE_URL=https://api.companionranchi.com
# Public HTTPS origin of the admin panel.
ADMIN_URL=https://admin.companionranchi.com

# ---- Database (PostgreSQL) ----
# Managed/remote DB: keep sslmode=require. Use a least-privilege app user.
DATABASE_URL=postgresql://companion_app:<STRONG_DB_PASSWORD>@<db-host>:5432/companion_ranchi?schema=public&sslmode=require

# ---- Auth / JWT ----
# Unique 64+ char random hex per secret. Rotating these forces all users to re-login.
JWT_ACCESS_SECRET=<64+ char random hex>
JWT_REFRESH_SECRET=<different 64+ char random hex>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ADMIN_JWT_SECRET=<different 64+ char random hex>

# ---- OTP / SMS ----
# In production OTP_CONSOLE MUST be false so real SMS is sent via MSG91.
OTP_CONSOLE=false
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
# MSG91 (India, DLT-registered). All three required when OTP_CONSOLE=false.
MSG91_AUTH_KEY=<MSG91 auth key>
MSG91_SENDER_ID=CMPRNC
MSG91_TEMPLATE_ID=<DLT-approved OTP template id>

# ---- Razorpay (LIVE) ----
RAZORPAY_KEY_ID=rzp_live_<your_live_key>
RAZORPAY_KEY_SECRET=<live key secret>
# Must EXACTLY match the secret you set on the Razorpay webhook.
RAZORPAY_WEBHOOK_SECRET=<webhook signing secret>
# RazorpayX for automated payouts (optional; manual admin payouts work without it).
RAZORPAYX_ACCOUNT_NUMBER=

# ---- Cloudflare R2 (S3 compatible) ----
R2_ACCOUNT_ID=<cloudflare account id>
R2_ACCESS_KEY_ID=<r2 access key id>
R2_SECRET_ACCESS_KEY=<r2 secret access key>
R2_BUCKET=companion-ranchi
# Public custom domain bound to the bucket (serves stored media URLs).
R2_PUBLIC_BASE_URL=https://media.companionranchi.com
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ---- Firebase Cloud Messaging ----
# Absolute path to the service-account JSON on the server (mounted as a secret file).
# This file is git-ignored; never commit it.
FIREBASE_SERVICE_ACCOUNT=/etc/secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=<firebase project id>

# ---- Business rules (override seeded settings defaults if needed) ----
DEFAULT_COMMISSION_RATE=20
REFERRAL_REWARD_AMOUNT=100
MIN_PAYOUT_AMOUNT=500
DEFAULT_CITY=Ranchi
MIN_AGE=18

# ---- CORS ----
# Comma-separated allowed origins. Include the admin panel (and any web client).
CORS_ORIGINS=https://admin.companionranchi.com

# ---- Admin seed (created by `npm run seed`) ----
# First super-admin login. ROTATE THE PASSWORD immediately after first login.
SEED_ADMIN_EMAIL=admin@companionranchi.com
SEED_ADMIN_PASSWORD=<strong unique password>

# ---- Realtime scale-out (optional) ----
# Required ONLY when running >1 backend instance (pm2 cluster / multiple replicas):
# enables the Socket.IO Redis adapter so messages reach sockets on every worker.
# REDIS_URL=redis://<redis-host>:6379

# ---- Admin build-time (Next.js) ----
# NOTE: set on the ADMIN service at BUILD time (inlined into the client bundle).
# NEXT_PUBLIC_API_BASE_URL=https://api.companionranchi.com
